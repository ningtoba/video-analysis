# ─────────────────────────────────────────────────────────────────────────────
# Video Analysis Platform — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env and set at least one LLM API key:
#   cp .env.example .env
#
# Then start:
#   docker compose up -d
#
# All settings are OPTIONAL except LLM_API_KEY / ANTHROPIC_API_KEY / GEMINI_API_KEY.
# ─────────────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════════════
# LLM PROVIDER (REQUIRED — at least one API key)
# ═══════════════════════════════════════════════════════════════════════════

# LLM provider: "openai" (default), "anthropic", "gemini", "deepseek", "ollama"
# LLM_PROVIDER=openai

# OpenAI / DeepSeek / OpenAI-compatible API key
LLM_API_KEY=sk-...

# Custom API base URL (e.g. https://api.deepseek.com for DeepSeek,
# or http://host.docker.internal:11434/v1 for local Ollama)
# LLM_API_BASE=

# Model name (auto-defaults based on provider if not set)
# OpenAI defaults: gpt-4o  |  Anthropic defaults: claude-3-5-sonnet-20241022
# Gemini defaults: gemini-2.0-flash-001  |  Ollama defaults: llama3.2-vision
# LLM_MODEL=

# LLM temperature (0.0 - 1.0)
# LLM_TEMPERATURE=0.3

# Alternative: Anthropic API key (used when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# Alternative: Gemini API key (used when LLM_PROVIDER=gemini)
# GEMINI_API_KEY=AIza...

# ═══════════════════════════════════════════════════════════════════════════
# ASR / WHISPER (auto-selected based on GPU VRAM)
# ═══════════════════════════════════════════════════════════════════════════

# Whisper model size. "auto" = best model for your GPU.
# Values: auto, tiny, base, small, medium, large-v3-turbo, large-v3
# WHISPER_MODEL=auto

# ═══════════════════════════════════════════════════════════════════════════
# FRAME EXTRACTION
# ═══════════════════════════════════════════════════════════════════════════

# Frames per second to extract for LLM Vision analysis
# Default: 0.2 (1 frame every 5 seconds)
# FRAME_RATE=0.2

# Maximum frames to send to LLM Vision per video
# Default: 30
# MAX_FRAMES_FOR_LLM=30

# ═══════════════════════════════════════════════════════════════════════════
# DATA DIRECTORIES
# ═══════════════════════════════════════════════════════════════════════════

# Root data directory
# VIDEO_ANALYSIS_DATA=data

# ═══════════════════════════════════════════════════════════════════════════
# HUGGING FACE TOKEN (for gated whisper models)
# ═══════════════════════════════════════════════════════════════════════════
# HF_TOKEN=hf_...
