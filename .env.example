# ─────────────────────────────────────────────────────────────────────────────
# Video Analysis Platform — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and adjust values for your environment.
#   cp .env.example .env
#
# All variables are OPTIONAL — the platform uses sensible defaults.
# Boolean values: "true" / "false" (case-insensitive)

# ═══════════════════════════════════════════════════════════════════════════
# DATA & PATHS
# ═══════════════════════════════════════════════════════════════════════════

# Root directory for all data (videos, frames, audio, chroma, clips, thumbnails)
# Default: data
VIDEO_ANALYSIS_DATA=data

# ═══════════════════════════════════════════════════════════════════════════
# UI / SERVER
# ═══════════════════════════════════════════════════════════════════════════

# Host to bind the web server
# Default: 0.0.0.0
VIDEO_ANALYSIS_HOST=0.0.0.0

# Port for the web server
# Default: 7860
VIDEO_ANALYSIS_PORT=7860

# Gradio authentication (set to enable password-protected UI)
# Leave empty to disable authentication
GRADIO_USER=admin
GRADIO_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════════
# LLM PROVIDER
# ═══════════════════════════════════════════════════════════════════════════

# LLM provider backend: "hermes" (local Hermes CLI) or "openai" (OpenAI-compatible API)
# Default: hermes
# LLM_PROVIDER=hermes

# API key for OpenAI-compatible LLM backends
# Required when LLM_PROVIDER=openai
LLM_API_KEY=sk-...

# Custom base URL for OpenAI-compatible API
# Examples:
#   https://api.openai.com/v1
#   https://api.deepseek.com/v1
#   http://localhost:1234/v1
# LLM_API_BASE=

# Model name sent to the OpenAI-compatible API
# Default: deepseek-ai/DeepSeek-V4-Flash
# LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash

# LLM temperature (0.0 - 1.0)
# Default: 0.3
# LLM_TEMPERATURE=0.3

# Maximum tokens in LLM response
# Default: 2048
# LLM_MAX_TOKENS=2048

# ═══════════════════════════════════════════════════════════════════════════
# ASR / WHISPER
# ═══════════════════════════════════════════════════════════════════════════

# ASR backend (only "faster-whisper" is currently implemented)
# Default: faster-whisper
# WHISPER_BACKEND=faster-whisper

# Whisper model size
# Values: large-v3, large-v3-turbo, large-v2, medium, small, tiny
# Default: large-v3
# WHISPER_MODEL=large-v3

# Whisper device: "cuda" or "cpu"
# Default: cuda
# WHISPER_DEVICE=cuda

# Whisper compute type
# Values: int8_float16, float16, int8
# Default: int8_float16
# WHISPER_COMPUTE_TYPE=int8_float16

# ═══════════════════════════════════════════════════════════════════════════
# FRAME EXTRACTION & PROCESSING
# ═══════════════════════════════════════════════════════════════════════════

# Frame extraction rate (frames per second)
# Default: 0.5 (1 frame every 2 seconds)
# FRAME_RATE=0.5

# Scene detection threshold (0.0 - 1.0, lower = more scenes detected)
# Default: 0.3
# SCENE_THRESHOLD=0.3

# Scene detection algorithm
# Values: adaptive, content, ffmpeg, histogram, hash
# Default: adaptive
# SCENE_DETECTOR=adaptive

# Frame storage mode
# Values: full (store all frames), tiered (store analysis + thumbnail sizes), compressed
# Default: tiered
# FRAME_STORAGE_MODE=tiered

# Processing mode
# Values: video_full, audio_only, auto
# Default: video_full
# PROCESSING_MODE=video_full

# Adaptive frame sampling (motion-based)
# Default: false
# ADAPTIVE_FRAME_SAMPLING=false

# DINOv2 perceptual frame compression
# Default: false
# DINO_FRAME_COMPRESSION=false

# DINOv2 compression threshold (0.0 - 1.0; lower = more aggressive compression)
# Default: 0.88
# DINO_FRAME_COMPRESSION_THRESHOLD=0.88

# DINOv2 model for frame compression
# Values: facebook/dinov2-small, facebook/dinov2-base
# Default: facebook/dinov2-small
# DINO_FRAME_COMPRESSION_MODEL=facebook/dinov2-small

# CLIP-similarity frame deduplication
# Default: false
# CLIP_FRAME_DEDUP=false

# CLIP deduplication threshold (0.0 - 1.0; frames above this similarity are dropped)
# Default: 0.92
# CLIP_FRAME_DEDUP_THRESHOLD=0.92

# ═══════════════════════════════════════════════════════════════════════════
# VIDEO QUALITY PRE-SCREENING
# ═══════════════════════════════════════════════════════════════════════════

# Enable quality pre-screening (blur, brightness, static frame detection)
# Default: true
# QUALITY_SCREENING_ENABLED=true

# Minimum Laplacian variance for blur detection (lower = more tolerant of blur)
# Default: 100.0
# QUALITY_MIN_BLUR_THRESHOLD=100.0

# Minimum brightness (below this = too dark)
# Default: 30.0
# QUALITY_MIN_BRIGHTNESS=30.0

# Maximum brightness (above this = too bright)
# Default: 225.0
# QUALITY_MAX_BRIGHTNESS=225.0

# Similarity threshold for static frame detection (0.0 - 1.0)
# Default: 0.98
# QUALITY_STATIC_THRESHOLD=0.98

# ═══════════════════════════════════════════════════════════════════════════
# YOLO OBJECT DETECTION & TRACKING
# ═══════════════════════════════════════════════════════════════════════════

# YOLO model path/name
# Default: yolo26x.pt
# YOLO_MODEL=yolo26x.pt

# YOLO detection confidence threshold
# Default: 0.25
# YOLO_CONFIDENCE=0.25

# Enable entity tracking (ByteTrack via Ultralytics)
# Default: true
# ENTITY_TRACKING_ENABLED=true

# Entity tracker type
# Values: bytetrack.yaml, botsort.yaml
# Default: bytetrack.yaml
# ENTITY_TRACKER_TYPE=bytetrack.yaml

# ═══════════════════════════════════════════════════════════════════════════
# CLIP / VISUAL EMBEDDINGS
# ═══════════════════════════════════════════════════════════════════════════

# OpenCLIP model name
# Values: ViT-L-14-quickgelu, ViT-H-14-quickgelu, ViT-B-32, ViT-SO400M-14-SigLIP-384
# Default: ViT-L-14-quickgelu
# CLIP_MODEL=ViT-L-14-quickgelu

# OpenCLIP pretrained dataset
# Values: dfn5b, laion2b_s34b_b79k, webli
# Default: dfn5b
# CLIP_PRETRAINED_DATASET=dfn5b

# ═══════════════════════════════════════════════════════════════════════════
# RAG / VECTOR DATABASE
# ═══════════════════════════════════════════════════════════════════════════

# Embedding model (primary — BGE-VL for multimodal text+image+composed embeddings)
# Default: BAAI/BGE-VL-base
# EMBEDDING_MODEL=BAAI/BGE-VL-base

# Text embedding model (SentenceTransformer fallback)
# Default: nomic-ai/nomic-embed-text-v2
# TEXT_EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v2

# Multimodal embedding model (opt-in legacy path)
# Default: Qwen/Qwen3-VL-Embedding-2B
# MULTIMODAL_EMBEDDING_MODEL=Qwen/Qwen3-VL-Embedding-2B

# Enable multimodal embedding
# Default: false
# MULTIMODAL_EMBEDDING=false

# Reranker model (cross-encoder)
# Default: cross-encoder/ms-marco-MiniLM-L-6-v2
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Chroma DB collection name
# Default: video_analysis
# CHROMA_COLLECTION=video_analysis

# Top-K retrieval (chunks to retrieve before re-ranking)
# Default: 20
# TOP_K_RETRIEVAL=20

# Top-K reranking (chunks to keep after re-ranking)
# Default: 5
# TOP_K_RERANK=5

# Temporal window (neighbors on each side for TV-RAG time-decay weighting)
# Default: 1
# TEMPORAL_WINDOW=1

# Temporal decay rate (0 = disabled)
# Default: 0.1
# TEMPORAL_DECAY_RATE=0.1

# Enable ColBERTv2 late-interaction reranker
# Default: false
# COLBERT_RERANKER_ENABLED=false

# Enable ColBERT-Att attention-weighted reranker
# Default: false
# COLBERT_ATT_RERANKER_ENABLED=false

# MMR diversity re-ranking
# Default: false
# MMR_DIVERSITY_ENABLED=false

# MMR lambda (0 = pure diversity, 1 = pure relevance)
# Default: 0.5
# MMR_LAMBDA=0.5

# MMR top-K
# Default: 15
# MMR_TOP_K=15

# ═══════════════════════════════════════════════════════════════════════════
# CONVERSATION MEMORY
# ═══════════════════════════════════════════════════════════════════════════

# Enable conversation memory (ChromaDB-backed Q&A memory)
# Default: true
# CONVERSATION_MEMORY_ENABLED=true

# Maximum number of conversation entries to retain
# Default: 50
# CONVERSATION_MEMORY_MAX_ENTRIES=50

# Conversation memory TTL in days
# Default: 30
# CONVERSATION_MEMORY_TTL_DAYS=30

# ═══════════════════════════════════════════════════════════════════════════
# SCENE GRAPH & QUERY ROUTING
# ═══════════════════════════════════════════════════════════════════════════

# Enable scene-graph retrieval layer
# Default: true
# SCENE_GRAPH_ENABLED=true

# Enable query classification and routing
# Default: true
# QUERY_ROUTING_ENABLED=true

# Enable multi-hop query decomposition
# Default: true
# MULTI_HOP_ENABLED=true

# Enable iterative agentic retrieval loop
# Default: true
# AGENTIC_RETRIEVAL_ENABLED=true

# Enable LLM-based self-check verification
# Default: true
# SELF_CHECK_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════
# YOUTUBE / URL IMPORT
# ═══════════════════════════════════════════════════════════════════════════

# Enable YouTube/URL video import
# Default: true
# YT_DLP_ENABLED=true

# yt-dlp format string
# Default: bestvideo[height<=1080]+bestaudio/best[height<=1080]
# YT_DLP_FORMAT=bestvideo[height<=1080]+bestaudio/best[height<=1080]

# ═══════════════════════════════════════════════════════════════════════════
# OCR (PaddleOCR)
# ═══════════════════════════════════════════════════════════════════════════

# Enable OCR text extraction
# Default: true
# OCR_ENABLED=true

# OCR confidence threshold (0.0 - 1.0)
# Default: 0.3
# OCR_CONFIDENCE=0.3

# OCR model version
# Values: PP-OCRv6, PP-OCRv5
# Default: PP-OCRv6
# OCR_MODEL_VERSION=PP-OCRv6

# OCR model tier (smaller = faster, less accurate)
# Values: tiny, small, medium
# Default: medium
# OCR_MODEL_TIER=medium

# ═══════════════════════════════════════════════════════════════════════════
# DIARIZATION (PyAnnote)
# ═══════════════════════════════════════════════════════════════════════════

# Enable speaker diarization
# Default: true
# DIARIZE_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════
# FACE RECOGNITION (InsightFace)
# ═══════════════════════════════════════════════════════════════════════════

# Enable face detection and recognition
# Default: false
FACE_RECOGNITION_ENABLED=false

# InsightFace model pack
# Default: buffalo_l
# FACE_DETECTION_MODEL=buffalo_l

# Face match threshold (cosine similarity for identity matching)
# Default: 0.45
# FACE_MATCH_THRESHOLD=0.45

# ═══════════════════════════════════════════════════════════════════════════
# VIDEO MLLM (VideoChat-Flash / SmolVLM2 / Qwen3-VL / InternVideo3)
# ═══════════════════════════════════════════════════════════════════════════

# Enable video MLLM (Multimodal Large Language Model)
# Default: false
VIDEO_MLLM_ENABLED=false

# MLLM model name
# Default: OpenGVLab/VideoChat-Flash-Qwen2_5-2B_res448
# VIDEO_MLLM_MODEL=OpenGVLab/VideoChat-Flash-Qwen2_5-2B_res448

# MLLM backend
# Values: auto, videochat_flash, smolvlm2, qwen3_vl
# Default: auto
# VIDEO_MLLM_BACKEND=auto

# MLLM model size (SmolVLM2 only)
# Values: 2.2B, 500M, 256M
# Default: 2.2B
# VIDEO_MLLM_MODEL_SIZE=2.2B

# Use MLLM for scene descriptions instead of OpenCLIP
# Default: false
# VIDEO_MLLM_AS_DESCRIBER=false

# Use MLLM as video-native Q&A backend instead of LLM provider
# Default: false
# VIDEO_MLLM_AS_CHAT_BACKEND=false

# ═══════════════════════════════════════════════════════════════════════════
# STREAMING PIPELINE
# ═══════════════════════════════════════════════════════════════════════════

# Enable streaming pipeline (chunked video processing)
# Default: false
STREAMING_ENABLED=false

# Streaming chunk duration in seconds
# Default: 30.0
# STREAMING_CHUNK_DURATION=30.0

# Streaming chunk overlap in seconds
# Default: 2.0
# STREAMING_OVERLAP=2.0

# Enable incremental indexing of streaming chunks to ChromaDB
# Default: true
# STREAMING_INCREMENTAL_INDEX=true

# Maximum chunks to process (0 = unlimited)
# Default: 0
# STREAMING_MAX_CHUNKS=0

# Enable streaming thinking (amortized reasoning during streaming)
# Default: false
STREAMING_THINKING_ENABLED=false

# ═══════════════════════════════════════════════════════════════════════════
# LIVE STREAM ANALYSIS (RTMP/RTSP/HLS)
# ═══════════════════════════════════════════════════════════════════════════

# Enable live stream capture and analysis
# Default: false
LIVE_STREAM_ENABLED=false

# Live stream URL (e.g. rtmp://example.com/live/stream)
# LIVE_STREAM_URL=

# Live stream source type
# Values: rtmp, rtsp, hls
# Default: rtmp
# LIVE_STREAM_SOURCE=rtmp

# Live stream chunk duration in seconds
# Default: 30.0
# LIVE_STREAM_CHUNK_DURATION=30.0

# Live stream sliding window in seconds (how much history to keep)
# Default: 300
# LIVE_STREAM_SLIDING_WINDOW=300

# Auto-reconnect on live stream disconnect
# Default: true
# LIVE_STREAM_AUTO_RECONNECT=true

# Maximum reconnection retries
# Default: 3
# LIVE_STREAM_MAX_RETRIES=3

# Retry delay between reconnection attempts in seconds
# Default: 5.0
# LIVE_STREAM_RETRY_DELAY=5.0

# ═══════════════════════════════════════════════════════════════════════════
# FEDERATED SEARCH
# ═══════════════════════════════════════════════════════════════════════════

# Enable federated video search across multiple instances
# Default: false
FEDERATION_ENABLED=false

# Comma-separated list of peer URLs
# FEDERATION_PEERS=http://192.168.1.50:8000,http://192.168.1.51:8000

# Federation request timeout in seconds
# Default: 30.0
# FEDERATION_TIMEOUT=30.0

# Include local index in federated results
# Default: true
# FEDERATION_INCLUDE_LOCAL=true

# ═══════════════════════════════════════════════════════════════════════════
# AGENTIC VIDEO UNDERSTANDING
# ═══════════════════════════════════════════════════════════════════════════

# Enable the multi-tool video understanding agent
# Default: false
AGENT_ENABLED=false

# Maximum tool invocations per query
# Default: 5
# AGENT_MAX_TOOLS=5

# Enable agent confidence (Robust-TO per-evidence trustworthiness scoring)
# Default: false
AGENT_CONFIDENCE_ENABLED=false

# Minimum frame trustworthiness threshold (0.0 - 1.0)
# Default: 0.3
# AGENT_CONFIDENCE_MIN_TRUST=0.3

# Confidence weight mode
# Values: tiered, continuous
# Default: tiered
# AGENT_CONFIDENCE_WEIGHT_MODE=tiered

# ═══════════════════════════════════════════════════════════════════════════
# HIERARCHICAL ORCHESTRA (HiCrew-inspired multi-agent)
# ═══════════════════════════════════════════════════════════════════════════

# Enable hierarchical multi-agent orchestrator
# Default: false
ORCHESTRA_ENABLED=false

# Maximum specialist agents per query
# Default: 5
# ORCHESTRA_MAX_AGENTS=5

# Early stopping confidence threshold (0.0 - 1.0)
# Default: 0.5
# ORCHESTRA_CONFIDENCE_THRESHOLD=0.5

# ═══════════════════════════════════════════════════════════════════════════
# CAMERA TAB
# ═══════════════════════════════════════════════════════════════════════════

# Enable webcam/camera capture and analysis tab
# Default: false
CAMERA_ENABLED=false

# ═══════════════════════════════════════════════════════════════════════════
# AUTONOMOUS VIDEO CURATOR
# ═══════════════════════════════════════════════════════════════════════════

# Enable autonomous video curator
# Default: false
CURATOR_ENABLED=false

# Curator curiosity level (0.0 - 1.0; higher = more exploratory)
# Default: 0.5
# CURATOR_CURIOSITY=0.5

# Maximum curator exploration iterations
# Default: 15
# CURATOR_MAX_ITERATIONS=15

# Curator output directory
# Default: <data_dir>/curator_output
# CURATOR_OUTPUT_DIR=

# ═══════════════════════════════════════════════════════════════════════════
# EVENT-CAUSAL RAG (arXiv:2605.06185)
# ═══════════════════════════════════════════════════════════════════════════

# Enable event-causal RAG (semantic event segmentation + SES graphs)
# Default: false
EVENT_CAUSAL_RAG_ENABLED=false

# Enable event-causal RAG in chat retrieval
# Default: false
EVENT_CAUSAL_RAG_IN_CHAT=false

# Enable automatic event indexing during pipeline processing
# Default: true
# EVENT_CAUSAL_RAG_INDEX_ON_PROCESS=true

# Event segmentation strategy
# Values: auto, llm, transcript, temporal
# Default: auto
# EVENT_SEGMENTATION_STRATEGY=auto

# ═══════════════════════════════════════════════════════════════════════════
# RATE LIMITING
# ═══════════════════════════════════════════════════════════════════════════

# Enable API rate limiting (token bucket)
# Default: true
# RATE_LIMIT_ENABLED=true

# Rate limiter capacity (max burst)
# Default: 100
# RATE_LIMIT_CAPACITY=100

# Rate limiter replenishment rate (tokens/second)
# Default: 1.6667 (100/minute)
# RATE_LIMIT_RATE=1.6667

# ═══════════════════════════════════════════════════════════════════════════
# WEBHOOK
# ═══════════════════════════════════════════════════════════════════════════

# Comma-separated list of webhook URLs to notify on pipeline completion
# WEBHOOK_URL=https://hooks.example.com/pipeline-complete

# Webhook request timeout in seconds
# Default: 5.0
# WEBHOOK_TIMEOUT=5.0

# ═══════════════════════════════════════════════════════════════════════════
# ACTION RECOGNITION (X-CLIP)
# ═══════════════════════════════════════════════════════════════════════════

# Enable action recognition
# Default: false
ACTION_RECOGNITION_ENABLED=false

# ═══════════════════════════════════════════════════════════════════════════
# GRADIO WORKFLOW
# ═══════════════════════════════════════════════════════════════════════════

# Enable Gradio Workflow visual pipeline builder tab
# Default: true
# WORKFLOW_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════
# PROMETHEUS METRICS
# ═══════════════════════════════════════════════════════════════════════════

# Enable Prometheus metrics export (/metrics endpoint)
# Default: true
# PROMETHEUS_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════
# STRUCTURED LOGGING
# ═══════════════════════════════════════════════════════════════════════════

# Enable structured logging (structlog)
# Default: true
# STRUCTURED_LOGGING_ENABLED=true

# Structured logging format
# Values: console, json, auto
# Default: auto
# STRUCTURED_LOGGING_FORMAT=auto

# Structured logging level
# Values: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
# STRUCTURED_LOGGING_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════════════════
# TELEMETRY (OpenTelemetry)
# ═══════════════════════════════════════════════════════════════════════════

# Enable OpenTelemetry distributed tracing
# Default: true
# TELEMETRY_ENABLED=true

# Standard OpenTelemetry environment variables
# OTEL_SERVICE_NAME=video-analysis
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# ═══════════════════════════════════════════════════════════════════════════
# ADAPTIVE PIPELINE SCALING
# ═══════════════════════════════════════════════════════════════════════════

# Enable adaptive pipeline scaling (dynamic quality/resolution based on VRAM)
# Default: true
# ADAPTIVE_SCALING_ENABLED=true

# Adaptive scaling policy
# Values: conservative, balanced, performance, auto
# Default: auto
# ADAPTIVE_SCALING_POLICY=auto

# ═══════════════════════════════════════════════════════════════════════════
# HUGGING FACE
# ═══════════════════════════════════════════════════════════════════════════

# Hugging Face authentication token (for gated model access and higher rate limits)
# Standard HF convention
# HF_TOKEN=hf_...

# ═══════════════════════════════════════════════════════════════════════════
# BATCH PROCESSING
# ═══════════════════════════════════════════════════════════════════════════

# Number of concurrent batch processing jobs
# Default: 1 (sequential queue)
# BATCH_CONCURRENT=1
